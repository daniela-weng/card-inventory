# ─── Supabase (required, Phase 0) ─────────────────────────────
# Get from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── App (required, Phase 0) ──────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron auth (reserved, agents added later) ─────────────────
# A random string. All /api/agents/* handlers verify this header.
CRON_SECRET=

# ─── Anthropic (Phase 3: Order Intake + Vendor Update agents) ─
ANTHROPIC_API_KEY=

# ─── Google OAuth (Phase 3: Gmail agent) ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── EasyPost (Phase 4: Tracking agent) ───────────────────────
EASYPOST_API_KEY=
